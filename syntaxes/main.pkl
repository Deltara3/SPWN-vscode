amends "schema.pkl"
import "bindings.pkl" as w
import* "src/*.pkl" as files

name = "SPWN"
scopeName = "source.spwn"

patterns {
    w.include("comments")
    w.include("literals")
    w.include("types")
    w.include("keywords")
    w.include("punctuation")
    w.include("blocks")
    w.include("operators")
}

repository {
    // Merge all files automagically.
    for (_, file in files) {
        ...file.repository!!
    }
}