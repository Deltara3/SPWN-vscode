amends "schema.pkl"
import "bindings.pkl" as w
import* "src/*.pkl" as files

name = "SPWN"
scopeName = "source.spwn"

patterns {
    w.include("root")
}

repository {
    ["root"] = w.group(new Listing {
        w.include("stringLiterals")
    })

    // Merge all files automagically.
    for (_, file in files) {
        ...file.repository!!
    }
}