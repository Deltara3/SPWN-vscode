amends "../schema.pkl"
import "../bindings.pkl" as w

local literalTable = new Mapping {
    ["stringRaw"] = Pair("raw", "r")
    ["stringUnindent"] = Pair("unindent", "u")
    ["stringBase64"] = Pair("base64", "64")
    ["stringPlain"] = Pair("plain", null)

    ["idExplicit"] = #"\d"#
    ["idRandom"] = #"\?"#

    ["numberBinary"] = Pair("bin", Pair("0b", "01"))
    ["numberOctal"] = Pair("oct", Pair("0o", "0-7"))
    ["numberHexadecimal"] = Pair("hex", Pair("0x", "0-9a-fA-F"))
    ["numberDecimal"] = Pair("dec", Pair(null, "0-9"))
}

local function stringMatch(type: String, prefix: String?) =
    let (prefixed = prefix != null)
    let (multi = type == "unindent")
    let (raw = type == "raw")
    let (group = if (prefixed) "2" else "1")

    w.spanEx(
        "string.quoted.\(type)",

        Pair(if (prefixed) #"\b(\#(prefix))(['"])"# else #"(['"])"#, new Mapping {
            when (prefixed) {
                ["1"] = w.capture("storage.type.string")
            }

            [group] = w.capture("punctuation.definition.string.begin")
        }),

        Pair(if (multi) #"(\2)"# else #"(\\#(group))|(\n)"#, new Mapping {
            ["1"] = w.capture("punctuation.definition.string.end")

            when (!multi) {
                ["2"] = w.capture("invalid.illegal.unclosed-string")
            }
        }),
        
        if (!raw) new Listing { w.include("stringEscapes") } else null
    )

local function idMatch(selector: String) =
    let (scope = if (selector == #"\?"#) "entity.name.type" else "constant.numeric.id")

    w.matchEx(null, 
        #"(?<![a-zA-Z_])\#(selector)+([gbic])\b"#,
        new Mapping {
            ["0"] = w.capture(scope)
            ["1"] = w.capture("storage.type.number")
        }
    )

local function numberMatch(base: String, prefix: String?, digits: String) =
    let (prefixed = prefix != null)
    let (shared = #"[\#(digits)][\#(digits)_]*"#)

    w.matchEx(null,
        if (prefixed) #"\b(\#(prefix))\#(shared)\b"# else #"\b\#(shared)\b"#,
        new Mapping {
            ["0"] = w.capture("constant.numeric.\(base)")

            when (prefixed) {
                ["1"] = w.capture("storage.type.number")
            }
        }
    )

repository {
    ["literals"] = w.group(new Listing {
        for (name, _ in literalTable) {
            w.include(name)
        }
    })

    // Add each type to the table in order.
    for (name, entry in literalTable) {
        when (name.startsWith("string")) {
            [name] = stringMatch(entry.first, entry.second)
        }

        when (name.startsWith("id")) {
            [name] = idMatch(entry)
        }

        when (name.startsWith("number")) {
            [name] = numberMatch(entry.first, entry.second.first, entry.second.second)
        }
    }

    ["stringEscapes"] = w.group(new Listing {
        w.match(
            "constant.character.escape",
            #"\\([nrt'"]|u\{[0-9a-fA-F]{1,6}\})"#
        )

        w.match(
            "invalid.illegal.escape",
            #"\\[^nrt'"\\u]|\\u(?!\{[0-9a-fA-F]{1,6}\})"#
        )
    })
}