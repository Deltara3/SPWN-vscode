extends "../schema.pkl"
import "../bindings.pkl" as w

hidden keywords = new Mapping {
    ["keyword.control.exception"] = "throw"
    ["variable.language"] = "self"

    ["constant.language"] = keywordListing(List(
        "true", "false", "null"
    ))

    ["keyword.control"] = keywordListing(List(
        "let",
        "if",
        "else",
        "while",
        "for",
        "break",
        "continue",
        "march",
        "return"
    ))

    ["storage.type"] = keywordListing(List(
        "type",
        "impl",
        "obj",
        "trigger"
    ))

    ["keyword.control.import"] = keywordListing(List(
        "import",
        "extract"
    ))

    ["keyword.other"] = keywordListing(List(
        "as",
        "in",
        "is"
    ))

    ["keyword.control.exception.deprecated"] = "error"

    ["keyword.other.deprecated"] = keywordListing(List(
        "has",
        "sync"
    ))

    ["keyword.control.deprecated"] = keywordListing(List(
        "switch",
        "case"
    ))
}

function keywordListing(words: List<String>) = words.join("|")

repository {
    ["keywords"] = w.group(new Listing {
        w.match("constant.language", #"\$"#)

        for (tag, regex in keywords) {
            w.match(tag, #"\b(\#(regex))\b"#)
        }
    })
}