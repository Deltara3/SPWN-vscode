extends "../schema.pkl"
import "../bindings.pkl" as w

hidden keywords = new Mapping {
    ["keyword.control.exception"] = "throw"
    ["variable.language"] = "self"

    ["constant.language"] = keywordListing(new Listing {
        "true"
        "false"
        "null"
    })

    ["keyword.control"] = keywordListing(new Listing {
        "let"
        "if"
        "else"
        "while"
        "for"
        "break"
        "continue"
        "march"
        "return"
    })

    ["storage.type"] = keywordListing(new Listing {
        "type"
        "impl"
        "obj"
        "trigger"
    })

    ["keyword.control.import"] = keywordListing(new Listing {
        "import"
        "extract"
    })

    ["keyword.other"] = keywordListing(new Listing {
        "as"
        "in"
        "is"
    })

    ["keyword.control.exception.deprecated"] = "error"

    ["keyword.other.deprecated"] = keywordListing(new Listing {
        "has"
        "sync"
    })

    ["keyword.control.deprecated"] = keywordListing(new Listing {
        "switch"
        "case"
    })
}

function keywordListing(words: Listing<String>) = words.join("|")

repository {
    ["keywords"] = w.group(new Listing {
        w.match("constant.language", #"\$"#)

        for (tag, regex in keywords) {
            w.match(tag, #"\b(\#(regex))\b"#)
        }
    })
}